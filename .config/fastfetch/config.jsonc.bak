{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "kitty",
    "source": "~/Downloads/DarkSideOfArch.png",
    "height": 19,
    "width": 38,
    "padding": {
      "top": 1,
      "left": 2
    },
    "color": {
      "1": "green",
      "2": "yellow"
    }
  },
  "display": {
    "separator": "  ",
    "color": {
      "keys": "yellow",
      "title": "green"
    }
  },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "display",
    "wm",
    "icons",
    "font",
    "terminal",
    "cpu",
    "gpu",
    "memory",
    "swap",
    "disk",
    "battery", 
    "break",
    "colors"
  ]
}
